# MongoDB Connection
# For development (local): mongodb://localhost:27017/demodb
# For production: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/demodb

# Server Configuration
# PORT: 1-65535 (default: 3501)
PORT=3501

# Environment: development, staging, production
NODE_ENV=development

# Logging Level: debug, info, warn, error (default: info)
LOG_LEVEL=info
